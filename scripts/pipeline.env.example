# Smart Research Intake Pipeline — environment variables
# Copy this file to pipeline.env, fill in values, then:
#   source scripts/pipeline.env && python3 scripts/build_pipeline.py

# n8n instance URL (default: http://localhost:5678)
# N8N_BASE_URL=http://localhost:5678

# n8n API key — Settings → n8n API → Create API key
N8N_API_KEY=

# Brave Search API key — https://api.search.brave.com/
BRAVE_API_KEY=

# Discord webhook URLs — right-click channel → Edit → Integrations → Webhooks
DISCORD_WEBHOOK_DROPZONE=
DISCORD_WEBHOOK_PAPERS=
DISCORD_WEBHOOK_PROJECTS=

# n8n workflow to replace (leave blank to skip deletion of old workflow)
# N8N_OLD_WORKFLOW_ID=

# n8n credential IDs (required — created by setup-n8n.sh, copy from n8n UI)
N8N_SSH_CRED_ID=
N8N_ANTH_CRED_ID=
