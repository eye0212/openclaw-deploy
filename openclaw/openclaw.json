{
  "version": "1",
  "gateway": {
    "bind": "loopback"
  },
  "profiles": {
    "default": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "fast": {
      "provider": "anthropic",
      "model": "claude-haiku-4-5-20251001",
      "temperature": 0.5,
      "max_tokens": 2048
    },
    "capable": {
      "provider": "anthropic",
      "model": "claude-opus-4-6",
      "temperature": 0.7,
      "max_tokens": 8192
    },
    "local": {
      "provider": "ollama",
      "model": "mistral",
      "base_url": "http://localhost:11434",
      "temperature": 0.7,
      "max_tokens": 4096
    },
    "local-fast": {
      "provider": "ollama",
      "model": "mistral",
      "base_url": "http://localhost:11434",
      "temperature": 0.3,
      "max_tokens": 1024
    }
  },
  "routing": {
    "default_profile": "default",
    "tasks": {
      "summarize":  "local-fast",
      "search":     "local-fast",
      "transcribe": "local-fast",
      "code":       "capable",
      "video":      "default",
      "research":   "default"
    }
  },
  "providers": {
    "anthropic": {
      "api_key_env": "ANTHROPIC_API_KEY"
    },
    "openai": {
      "api_key_env": "OPENAI_API_KEY"
    },
    "google": {
      "api_key_env": "GOOGLE_API_KEY"
    },
    "ollama": {
      "base_url": "http://localhost:11434"
    }
  },
  "channels": {
    "telegram": {
      "token_env": "TELEGRAM_BOT_TOKEN",
      "allowed_chat_ids": [],
      "dmPolicy": "pairing"
    }
  },
  "tools": {
    "allow": ["web_search", "web_fetch", "memory_search", "memory_get", "message",
              "nodes", "exec", "read", "write", "cron"],
    "deny":  ["bash", "process", "edit", "browser", "gateway"]
  },
  "memory": {
    "embeddings": {
      "provider": "ollama",
      "model": "nomic-embed-text",
      "base_url": "http://localhost:11434"
    }
  },
  "mcp": {
    "servers": []
  },
  "skills_dir": "/home/openclaw/.openclaw/skills",
  "memory_dir": "/home/openclaw/.openclaw",
  "log_level_env": "OPENCLAW_LOG_LEVEL"
}
