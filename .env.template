# ============================================================
# OpenClaw Environment Configuration
# Generated by deploy.sh — do not edit placeholders manually
# ============================================================

# --- VPS ---
VPS_IP=__VPS_IP__
TAILSCALE_IP=__TAILSCALE_IP__
SSH_PORT=__SSH_PORT__

# --- User ---
USER_FIRST_NAME=__USER_FIRST_NAME__

# --- Timezone ---
TZ=__TIMEZONE__

# --- Anthropic ---
ANTHROPIC_API_KEY=__ANTHROPIC_API_KEY__

# --- Optional LLM providers ---
OPENAI_API_KEY=__OPENAI_API_KEY__
GOOGLE_API_KEY=__GOOGLE_API_KEY__

# --- Telegram ---
TELEGRAM_BOT_TOKEN=__TELEGRAM_BOT_TOKEN__

# --- n8n ---
# Basic auth was removed in n8n v1.0; first-time setup creates the owner account via the UI.
N8N_JWT_SECRET=__N8N_JWT_SECRET__
N8N_ENCRYPTION_KEY=__N8N_ENCRYPTION_KEY__
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://__TAILSCALE_IP__:5678/

# --- Webhook ---
WEBHOOK_SECRET=__WEBHOOK_SECRET__

# --- Whisper ---
WHISPER_MODEL=base
WHISPER_LANGUAGE=en

# --- Ollama ---
OLLAMA_HOST=0.0.0.0
# OLLAMA_ORIGINS: covers both localhost aliases to prevent CORS rejections from Docker services
OLLAMA_ORIGINS=http://localhost:11434,http://127.0.0.1:11434

# Ollama default model (used for openclaw "local" profile and pulled on setup)
OLLAMA_MODEL=mistral

# --- OpenClaw ---
OPENCLAW_LOG_LEVEL=info

# --- Image tags ---
# Pin to known-good versions for reproducible deployments.
# Check release pages before upgrading.
N8N_IMAGE_TAG=latest
UPTIME_KUMA_IMAGE_TAG=1.23.13
WHISPER_IMAGE_TAG=latest
OLLAMA_IMAGE_TAG=0.6.2
OPENCLAW_IMAGE_TAG=latest
